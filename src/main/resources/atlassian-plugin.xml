<atlassian-plugin key="${project.groupId}.${project.artifactId}" name="${project.name}" plugins-version="2">
    <plugin-info>
        <description>${project.description}</description>
        <version>${project.version}</version>
        <vendor name="${project.organization.name}" url="${project.organization.url}" />
        <param name="plugin-logo">/io/stykmartin/prombambooexporter/images/prom-exporter.png</param>
        <param name="plugin-icon">/io/stykmartin/prombambooexporter/images/prom-exporter-sm.png</param>
        <param name="plugin-banner">/io/stykmartin/prombambooexporter/images/banner.png</param>
        <param name="configure.url">/admin/prommetrics/settings.action</param>
        <param name="atlassian-data-center-compatible">true</param>
    </plugin-info>

    <!-- I18N -->
    <resource type="i18n" name="i18n" location="io.stykmartin.prombambooexporter.i18n.prom-bamboo-exporter"/>

    <!-- Web Items -->
    <web-item name="Security Token Admin Settings Link" key="prom-bamboo-exporter-configuration" section="system.admin/plugins" weight="100">
        <label key="io.stykmartin.prombambooexporter.admin.section"/>
        <description key="io.stykmartin.prombambooexporter.admin.section.desc"/>
        <link linkId="prom-bamboo-exporter-configuration">/admin/prommetrics/settings.action</link>
    </web-item>

    <!-- Actions -->
    <xwork name="Security Token Actions" key="prom-bamboo-exporter-actions">
        <package name="prom-bamboo-exporter-action-admin" extends="admin" namespace="/admin/prommetrics">
            <action name="settings" class="io.stykmartin.prombambooexporter.action.admin.SecureTokenConfigAction" method="input">
                <result name="input" type="freemarker">/io/stykmartin/prombambooexporter/templates/admin/settings.ftl</result>
                <result name="error" type="freemarker">/io/stykmartin/prombambooexporter/templates/admin/settings.ftl</result>
            </action>
            <action name="savesettings" class="io.stykmartin.prombambooexporter.action.admin.SecureTokenConfigAction">
                <result name="error" type="freemarker">/io/stykmartin/prombambooexporter/templates/admin/settings.ftl</result>
                <result name="success" type="freemarker">/io/stykmartin/prombambooexporter/templates/admin/settings.ftl</result>
            </action>
        </package>
    </xwork>

    <!-- Servlets -->
    <servlet name="Exporter Servlet" key="prom-bamboo-exporter-servlet" class="io.stykmartin.prombambooexporter.servlet.PrometheusExporter">
        <url-pattern>/prometheus/metrics</url-pattern>
    </servlet>

    <!-- Freemarker member access allowlist (Bamboo 12+) -->
    <freemarkerAllowlist key="freemarkerAllowlist">
        <method>io.stykmartin.prombambooexporter.action.admin.SecureTokenConfigAction.isSaved()</method>
        <method>io.stykmartin.prombambooexporter.action.admin.SecureTokenConfigAction.isTokenConfigured()</method>
    </freemarkerAllowlist>
</atlassian-plugin>
